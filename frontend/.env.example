VITE_APP_NAME="Smart Cafe Management System"
# Local dev: leave VITE_API_URL unset so the SPA uses same-origin /api (Vite proxy → Laravel :8000).
# Production: if unset, the app uses the default Heroku API in code. Override with your own URL
# (no trailing slash), e.g. VITE_API_URL=https://smartcafe-backend-3d04a0fbb50e.herokuapp.com
# Used to build customer QR payment links; defaults to window.location.origin
VITE_FRONTEND_URL=http://localhost:5173
# Set to true only when Laravel Reverb is running (`php artisan reverb:start`). Otherwise leave false.
VITE_ENABLE_REALTIME=false
VITE_REVERB_APP_KEY=smart-cafe-key
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http
